# Neon PostgreSQL接続文字列（サーバー専用）
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# NextAuth署名キー（十分に長いランダム文字列）
AUTH_SECRET=replace-with-a-long-random-secret

# Google OAuth（サーバー専用）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Ably APIキー（サーバー専用・値はコミットしない）
# Vercelでは名前をABLY_API_KEY、値を「Ably APIキー本体」に分けて登録してください。
# 値側に「ABLY_API_KEY=」という文字列や引用符を含めないでください。
# 絶対にNEXT_PUBLIC_接頭辞を付けないでください。
ABLY_API_KEY=
